pipeline {
    agent {
        label 'agent1'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'composer install --no-interaction --prefer-dist'
            }
        }

        stage('Setup Environment') {
            steps {
                sh 'cp .env.example .env'
                sh 'php artisan key:generate'
                sh 'touch database/database.sqlite'
                sh 'php artisan migrate --force'
            }
        }

        stage('NPM Build') {
            steps {
                sh 'npm install'
                sh 'npm run build'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'php artisan test'
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh 'ansible-playbook -i /etc/ansible/inventory.ini playbooks.yml -v'
            }
        }
    }

post {

    success {
        mail(
            to: 'moniromyi@gmail.com',
            subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: """
Build Success

Job: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}
Branch: laravel

Build URL:
${env.BUILD_URL}
"""
        )
    }

    failure {
        mail(
            to: 'moniromyi@gmail.com',
            subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: """
Build Failed

Job: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}

Build Logs:
${env.BUILD_URL}
"""
        )
    }

    unstable {
        mail(
            to: 'moniromyi@gmail.com',
            subject: "UNSTABLE: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
            body: """
Build Unstable

Job: ${env.JOB_NAME}
Build: #${env.BUILD_NUMBER}

Build URL:
${env.BUILD_URL}
"""
        )
    }
}

}
