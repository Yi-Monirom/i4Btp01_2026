pipeline {
    agent {
        label 'agent1'
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'composer install --no-interaction --prefer-dist'
            }
        }

        stage('Setup Environment') {
            steps {
                sh 'cp .env.example .env'
                sh 'php artisan key:generate'
                sh 'touch database/database.sqlite'
                sh 'php artisan migrate --force'
            }
        }

        stage('NPM Build') {
            steps {
                sh 'npm install'
                sh 'npm run build'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'php artisan test'
            }
        }

        stage('Deploy with Ansible') {
            steps {
                sh 'ansible-playbook -i /etc/ansible/inventory.ini playbooks.yml -v'
            }
        }
    }

    post {
        success {
            
            sh "curl -s -X POST https://api.telegram.org/bot8612978489:AAE9XKdKkNt9df3XZ5s1u69WLLP4vUFAk9o/sendMessage -d chat_id=1442383271 -d text='deploy success'"
            echo 'All tests passed! CI/CD pipeline completed successfully.'
        }
        failure {
            d
            sh "curl -s -X POST https://api.telegram.org/bot8612978489:AAE9XKdKkNt9df3XZ5s1u69WLLP4vUFAk9o/sendMessage -d chat_id=1442383271 -d text='deploy fail'"
            echo 'Pipeline failed. Check logs for details.'
        }
    }
}
